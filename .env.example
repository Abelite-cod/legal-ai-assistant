# ─────────────────────────────────────────────────────────────
# Legal AI Assistant — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────
# Get your key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Optional ──────────────────────────────────────────────────
# Database URL (defaults to SQLite if not set)
# For SQLite (local dev — no setup needed):
# DATABASE_URL=sqlite:///./legal_ai.db
#
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/legal_ai
DATABASE_URL=sqlite:///./legal_ai.db
